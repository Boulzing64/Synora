{
    "name":  "@synora/contracts",
    "version":  "0.1.0",
    "private":  true,
    "type":  "module",
    "scripts":  {
                    "dev":  "hardhat node",
                    "compile":  "hardhat compile",
                    "test":  "hardhat test",
                    "clean":  "hardhat clean",
                    "deploy:local":  "hardhat ignition deploy ./ignition/modules/SYNORA.ts",
                    "deploy:base-sepolia":  "hardhat ignition deploy ./ignition/modules/SYNORA.ts --network baseSepolia",
                    "deploy:rewards:base-sepolia":  "hardhat ignition deploy ./ignition/modules/RewardsDistributor.ts --network baseSepolia --parameters ./ignition/parameters/base-sepolia-rewards.json",
                    "deploy:staking:base-sepolia":  "hardhat ignition deploy ./ignition/modules/SYNStaking.ts --network baseSepolia --parameters ./ignition/parameters/base-sepolia-staking.json"
                },
    "devDependencies":  {
                            "@nomicfoundation/hardhat-toolbox-viem":  "^5.0.7",
                            "@types/node":  "^25.9.2",
                            "hardhat":  "^3.9.0",
                            "typescript":  "^6.0.3"
                        },
    "dependencies":  {
                         "@openzeppelin/contracts":  "^5.6.1"
                     }
}